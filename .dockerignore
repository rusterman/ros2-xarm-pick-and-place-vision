# ── Nothing is COPYed in the Dockerfile ──────────────────────
# src and config are mounted as volumes at runtime.
# Everything below is excluded to keep the build context
# minimal and avoid sending large or irrelevant files
# to the Docker daemon.

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore
.dockerignore

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Claude Code internal ──────────────────────────────────────
.claude/

# ── macOS binary (wrong arch for Linux, ~15 MB) ───────────────
bin/

# ── Mounted as volumes at runtime, not COPYed ─────────────────
src/
config/

# ── ROS2 build artifacts ──────────────────────────────────────
build/
install/
log/

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/

# ── C++ build artifacts ───────────────────────────────────────
*.o
*.so
*.a
CMakeCache.txt
CMakeFiles/

# ── Editor and IDE ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docs and scripts (not needed inside container) ────────────
docs/
scripts/*
!scripts/entrypoint.sh
README.md

# ── Temporary xarm reference files ───────────────────────────
xarm/
